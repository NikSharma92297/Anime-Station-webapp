# Copy this file to .env for local testing. On Render, set these as
# environment variables in the dashboard instead (see render.yaml / README).

# --- Telegram (same bot as the bot service) -------------------------------
BOT_TOKEN=                        # same token the bot uses

# --- Database (shared with the bot — use the SAME values there) ----------
DATABASE_URL=                     # mongodb+srv://... connection string
DATABASE_NAME=AnimeStation

# --- Owner --------------------------------------------------------------
OWNER_ID=                         # your numeric Telegram user ID (fallback super-admin)

# --- Bot integration -------------------------------------------------------
BOT_INTERNAL_URL=                 # your deployed bot's URL, e.g. https://anime-station-bot.onrender.com
WEBAPP_SECRET=                    # random string — must match WEBAPP_SECRET on the bot service

# --- Channels (shared with the bot) ----------------------------------------
ADMIN_REQUESTS_CHANNEL_ID=        # -100... ID of the channel where anime requests get posted (matches the bot)
REPORTS_CHANNEL_ID=                # -100... ID of the channel where anime issue reports get posted

# --- Misc -----------------------------------------------------------------
MAX_DAILY_REQUESTS=4               # max new anime requests a single user can submit per rolling 24h window

# --- Render only -----------------------------------------------------------
# PORT is injected automatically by Render — do not set it yourself.
